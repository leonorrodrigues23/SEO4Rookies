const methodology = [
  { number: "01", title: "Ease of Use & Learning Curve", description: "We evaluate setup time, interface clarity, and how quickly a beginner can get actionable insights. The best SEO tools deliver value on day one without requiring a certification to understand." },
  { number: "02", title: "Data Accuracy & Coverage", description: "We compare keyword databases, backlink indexes, and crawl coverage across tools. Accurate data is the foundation of good SEO decisions—tools with stale or incomplete data can lead you astray." },
  { number: "03", title: "Feature Depth & Value", description: "We test every major feature—keyword research, site audits, rank tracking, competitor analysis—and evaluate whether the pricing justifies the capability set compared to alternatives." },
  { number: "04", title: "Real-World Results & Support", description: "We use these tools on live websites and measure actual outcomes. We also test customer support responsiveness, documentation quality, and community resources." }
];

const criteria = [
  { icon: "shield", color: "green", title: "Data Accuracy", description: "Reliable keyword volumes, backlink counts, and ranking data you can trust to make real business decisions." },
  { icon: "dollar", color: "blue", title: "Value for Money", description: "Competitive pricing with clear ROI. The best tools pay for themselves through organic traffic gains." },
  { icon: "users", color: "purple", title: "Beginner-Friendly", description: "Intuitive interfaces with guided workflows so you can start improving rankings without being an expert." },
  { icon: "document", color: "orange", title: "Feature Completeness", description: "Comprehensive toolsets covering keyword research, audits, tracking, and competitive analysis in one platform." }
];

const faqs = [
  {
    question: "What is the best SEO tool for beginners in 2026?",
    answer: "Moz is our top pick for beginners thanks to its intuitive interface, guided workflows, and world-class educational resources like Moz Academy and the Beginner's Guide to SEO. Ubersuggest is also excellent if you're on a tight budget."
  },
  {
    question: "Do I need to pay for an SEO tool or are free options enough?",
    answer: "Free tools like Google Search Console, Google Analytics, and Moz's free MozBar extension can get you started. However, paid tools provide deeper keyword data, competitor insights, and automated auditing that save significant time and reveal opportunities free tools miss."
  },
  {
    question: "What is the difference between Moz, Ahrefs, and SEMrush?",
    answer: "Moz excels at usability and its Domain Authority metric. Ahrefs has the largest backlink index and is best for link building. SEMrush offers the most features including PPC research and social media tools. Choose based on your primary need: Moz for all-around use, Ahrefs for links, SEMrush for multi-channel marketing."
  },
  {
    question: "How much should I spend on SEO tools?",
    answer: "Budget-conscious users can start with Ubersuggest at $12/month or its lifetime plan. Mid-range users should look at Moz ($49/month). Agencies and power users typically invest $129-$250/month in tools like Ahrefs or SEMrush. The right budget depends on your traffic goals and revenue from organic search."
  },
  {
    question: "Can SEO tools guarantee higher rankings?",
    answer: "No tool can guarantee rankings—Google's algorithm considers hundreds of factors. However, SEO tools give you the data and insights to make informed decisions, find opportunities, fix technical issues, and track progress. They dramatically increase your odds of ranking success."
  },
  {
    question: "How often should I audit my website with SEO tools?",
    answer: "Run a full technical audit at least once per month. Track your keyword rankings weekly. Monitor backlinks continuously. Most paid tools can automate these tasks with scheduled crawls and alerts so you catch issues quickly."
  }
];

function getStarRating(rating: number) {
  const fullStars = Math.floor(rating);
  const partialFill = (rating - fullStars) * 100;
  const emptyStars = 5 - Math.ceil(rating);
  return { fullStars, partialFill, emptyStars, hasPartial: partialFill > 0 };
}
