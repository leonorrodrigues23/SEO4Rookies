<MainLayout title={articleConfig.title} description={articleConfig.subtitle}>
  
  <!-- HERO SECTION -->
  <section class="hero-section">
    <div class="hero-container">
      <div class="hero-content">
        <div class="hero-meta">
          <span class="category-tag">{articleConfig.category}</span>
          <span class="separator">&bull;</span>
          <span class="reading-time">{articleConfig.readingTime}</span>
        </div>
        <h1 class="hero-title">{articleConfig.title}</h1>
        <p class="hero-subtitle">{articleConfig.subtitle}</p>
        <div class="author-card">
          <img src={author.image} alt={author.name} class="author-image" onerror="this.src='https://ui-avatars.com/api/?name=AT&background=1a365d&color=fff&size=96'" />
          <div class="author-details">
            <div class="author-name">{author.name}</div>
            <div class="author-title">{author.title}</div>
          </div>
          <div class="author-date">
            <span>Updated</span>
            <strong>{testingStats.lastUpdated}</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="trust-section">
    <div class="trust-container">
      <div class="trust-badges">
        <div class="trust-badge">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><strong>{testingStats.productsTested}</strong> tools tested</span>
        </div>
        <div class="trust-badge">
