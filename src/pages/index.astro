---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_BRAND } from '../consts';
import { getAuthorByCategory } from '../authors';

const articleConfig = {
  category: "SEO Tools",
  title: "Best SEO Tools for 2026",
  subtitle: "SEO doesn't have to be overwhelming. We cut through the noise, test the tools hands-on, and compare what actually matters so you can pick the right platform and start ranking.",
  readingTime: "14 min read"
};

const author = getAuthorByCategory(articleConfig.category, articleConfig.title, ['seo', 'tools', 'ranking']);

const testingStats = {
  productsTested: 35,
  hoursOfTesting: 300,
  expertsInvolved: 5,
